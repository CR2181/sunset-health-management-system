NODE_ENV=development
PORT=3000

# Local pilot database. Keep this local until a cloud database is purchased.
# Supported values: mysql or postgres
DB_TYPE=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USERNAME=root
DB_PASSWORD=local-development-password
DB_DATABASE=sunset_health
DB_SYNC=true
SEED_DEMO_DATA=true

JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=8h
ALLOW_SELF_REGISTRATION=false
AUTH_RATE_LIMIT_MAX=20
AUTH_RATE_LIMIT_WINDOW_MS=900000
CORS_ORIGINS=http://127.0.0.1:5177,http://localhost:5177,http://127.0.0.1:8080,http://localhost:8080

# Vision defaults to explicit mock events. local_yolo calls a separately managed local service.
AI_DETECTOR_MODE=mock
AI_SERVICE_URL=http://127.0.0.1:8090
AI_SERVICE_TIMEOUT_MS=1500
AI_MODEL_VERSION=mock-v1
AI_CONFIDENCE_THRESHOLD=0.65
AI_FRAME_INTERVAL_MS=1000
AI_MAX_FRAME_BYTES=1048576
AI_ALERT_DEDUPE_SECONDS=60
AI_FALLBACK_TO_MOCK=true

# LLM summaries are disabled for the MVP. Never commit a real key.
LLM_ENABLED=false
LLM_PROVIDER=none
LLM_API_KEY=
